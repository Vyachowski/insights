# --- Docker Compose (apps/backend/docker-compose.dev.yml) ---
DB_CONTAINER=insights-pg
DB_USER=insights
DB_PASSWORD=insights
DB_NAME=insights
DB_PORT=5432

# --- Nest / Prisma ---
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://insights:insights@localhost:5432/insights
ALLOWED_ORIGIN=http://localhost:5173

JWT_SECRET=change-me
JWT_EXPIRATION=7d
JWT_MAX_AGE=604800000

YANDEX_API_OAUTH_TOKEN=change-me

# Optional (defaults exist in validation schema)
# DATABASE_CONNECT_RETRIES=5
# DATABASE_CONNECT_DELAY=3000

# --- Prisma seed (users) — required when running db:seed ---
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_NAME=
# ADMIN_LASTNAME=
# USER_EMAIL=
# USER_PASSWORD=
# USER_NAME=
# USER_LASTNAME=
