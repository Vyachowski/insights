{
  "name": "insights",
  "version": "0.1.0",
  "description": "A business dashboard for key analytics values for business",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "frontend:dev": "npm run dev --workspace @insights/frontend",
    "frontend:build": "npm run build --workspace @insights/frontend",
    "backend:dev": "npm run dev --workspace @insights/backend",
    "backend:start": "npm run start:prod --workspace @insights/backend",
    "backend:build": "npm run build --workspace @insights/backend",
    "db:seed": "npm run prisma:seed --workspace @insights/backend"
  },
  "author": "Slava Haikin",
  "license": "UNLICENSED",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "knip": "^5.86.0"
  }
}
